generator client {
    provider = "prisma-client-js"
}

datasource db {
    provider = "postgresql"
    url      = env("DATABASE_URL")
}

enum UserRole {
    ADMIN
    USER
}

model User {
    id         Int          @id @default(autoincrement())
    surname    String
    name       String
    patronymic String?
    role       UserRole
    UserBasket UserBasket[]
}

model UserBasket {
    id            Int         @id @default(autoincrement())
    quantity      Int         @default(1)
    userId        Int
    user          User        @relation(fields: [userId], references: [id])
    productItemId Int
    productItem   ProductItem @relation(fields: [productItemId], references: [id])
}

model Category {
    id       Int       @id @default(autoincrement())
    title    String    @unique
    products Product[]
}

model Product {
    id          Int    @id @default(autoincrement())
    title       String
    description String
    imageUrl    String
    rating      Int

    quantity     Int           @default(1)
    categoryId   Int
    category     Category      @relation(fields: [categoryId], references: [id])
    Ingredient   Ingredient[]
    productItems ProductItem[]
}

model ProductItem {
    id         Int          @id @default(autoincrement())
    price      Int
    productId  Int
    product    Product      @relation(fields: [productId], references: [id])
    UserBasket UserBasket[]
    sizeId     Int?
    size       SizeOption?  @relation(fields: [sizeId], references: [id])
    typeId     Int?
    type       TypeOption?  @relation(fields: [typeId], references: [id])
}

model Ingredient {
    id        Int     @id @default(autoincrement())
    img       String
    title     String
    price     Int
    productId Int
    product   Product @relation(fields: [productId], references: [id])
}

model SizeOption {
    id           Int           @id @default(autoincrement())
    size         Int
    price        Int?
    productItems ProductItem[]
}

model TypeOption {
    id           Int           @id @default(autoincrement())
    type         String
    price        Int?
    productItems ProductItem[]
}

model Sorting {
    id    Int    @id @default(autoincrement())
    title String
}

model Filter {
    id    Int    @id @default(autoincrement())
    title String
}
